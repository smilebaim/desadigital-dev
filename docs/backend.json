{
  "entities": {
    "Penduduk": {
      "title": "Penduduk",
      "type": "object",
      "properties": {
        "nama": {
          "type": "string",
          "description": "Nama lengkap penduduk."
        },
        "nik": {
          "type": "string",
          "description": "Nomor Induk Kependudukan."
        },
        "kk": {
          "type": "string",
          "description": "Nomor Kartu Keluarga."
        },
        "jenisKelamin": {
          "type": "string",
          "enum": [
            "Laki-laki",
            "Perempuan"
          ]
        },
        "tempatLahir": {
          "type": "string"
        },
        "tanggalLahir": {
          "type": "string",
          "format": "date"
        },
        "agama": {
          "type": "string"
        },
        "pendidikan": {
          "type": "string"
        },
        "pekerjaan": {
          "type": "string"
        },
        "statusPerkawinan": {
          "type": "string",
          "enum": [
            "Belum Kawin",
            "Kawin",
            "Cerai Hidup",
            "Cerai Mati"
          ]
        },
        "alamat": {
          "type": "string"
        },
        "rt": {
          "type": "string"
        },
        "rw": {
          "type": "string"
        }
      },
      "required": [
        "nama",
        "nik",
        "kk",
        "jenisKelamin",
        "tempatLahir",
        "tanggalLahir",
        "agama",
        "pendidikan",
        "pekerjaan",
        "statusPerkawinan",
        "alamat",
        "rt",
        "rw"
      ]
    },
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "Nama tampilan pengguna."
        },
        "email": {
          "type": "string",
          "description": "Alamat email pengguna.",
          "format": "email"
        },
        "photoURL": {
          "type": "string",
          "description": "URL foto profil pengguna.",
          "format": "uri"
        }
      },
      "required": [
        "displayName",
        "email"
      ]
    },
    "Workspace": {
      "title": "Workspace",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Nama dari workspace."
        },
        "description": {
          "type": "string",
          "description": "Deskripsi singkat dari workspace."
        },
        "ownerUid": {
          "type": "string",
          "description": "User ID dari pemilik workspace."
        },
        "members": {
          "type": "array",
          "description": "Array dari UID pengguna yang menjadi anggota workspace.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "name",
        "ownerUid"
      ]
    },
    "WorkspaceItem": {
      "title": "Workspace Item",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Judul dari item workspace."
        },
        "description": {
          "type": "string",
          "description": "Deskripsi atau catatan detail dari item."
        },
        "label": {
          "type": "string",
          "description": "Label atau kategori untuk item."
        },
        "completed": {
          "type": "boolean",
          "description": "Status penyelesaian item."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Waktu item dibuat."
        },
        "attachments": {
          "type": "array",
          "description": "Daftar lampiran file untuk item ini.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "path": {
                "type": "string"
              }
            },
            "required": [
              "name",
              "url",
              "path"
            ]
          }
        }
      },
      "required": [
        "title"
      ]
    },
    "CustomPage": {
      "title": "Custom Page",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the page."
        },
        "slug": {
          "type": "string",
          "description": "The URL-friendly slug for the page."
        },
        "content": {
          "type": "string",
          "description": "The main content of the page, can be Markdown or HTML."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "title",
        "slug",
        "content"
      ]
    },
    "Statistik": {
      "title": "Statistik",
      "type": "object",
      "properties": {
        "key": {
          "type": "string",
          "description": "Unique key to identify the statistic (e.g., 'pendapatan_desa')."
        },
        "title": {
          "type": "string",
          "description": "Display title for the statistic (e.g., 'Pendapatan Desa')."
        },
        "group": {
          "type": "string",
          "description": "Grouping for the statistic (e.g., 'Anggaran', 'IDM')."
        },
        "data": {
          "type": "string",
          "description": "JSON string representing the chart data."
        }
      },
      "required": ["key", "title", "group", "data"]
    },
    "SuratUsaha": {
      "title": "Surat Keterangan Usaha",
      "type": "object",
      "properties": {
        "pendudukId": { "type": "string" }, "namaPemohon": { "type": "string" }, "nikPemohon": { "type": "string" },
        "namaUsaha": { "type": "string" }, "jenisUsaha": { "type": "string" }, "alamatUsaha": { "type": "string" },
        "status": { "type": "string", "enum": ["Diproses", "Selesai", "Ditolak"] }, "nomorSurat": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["pendudukId", "namaPemohon", "nikPemohon", "namaUsaha", "jenisUsaha", "alamatUsaha", "status"]
    },
    "SuratDomisili": {
      "title": "Surat Keterangan Domisili",
      "type": "object",
      "properties": {
        "pendudukId": { "type": "string" }, "namaPemohon": { "type": "string" }, "nikPemohon": { "type": "string" },
        "status": { "type": "string", "enum": ["Diproses", "Selesai", "Ditolak"] }, "nomorSurat": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["pendudukId", "namaPemohon", "nikPemohon", "status"]
    },
    "SuratKelahiran": {
      "title": "Surat Keterangan Kelahiran",
      "type": "object",
      "properties": {
        "pendudukId_ibu": { "type": "string" },
        "namaIbu": { "type": "string" },
        "nikIbu": { "type": "string" },
        "pendudukId_ayah": { "type": "string" },
        "namaAyah": { "type": "string" },
        "nikAyah": { "type": "string" },
        "namaBayi": { "type": "string" },
        "jenisKelaminBayi": { "type": "string", "enum": ["Laki-laki", "Perempuan"] },
        "tempatLahirBayi": { "type": "string" },
        "tanggalLahirBayi": { "type": "string", "format": "date" },
        "waktuLahirBayi": { "type": "string", "format": "time" },
        "namaSaksi1": { "type": "string" },
        "namaSaksi2": { "type": "string" },
        "status": { "type": "string", "enum": ["Diproses", "Selesai", "Ditolak"] },
        "nomorSurat": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["pendudukId_ibu", "pendudukId_ayah", "namaBayi", "jenisKelaminBayi", "tempatLahirBayi", "tanggalLahirBayi", "status"]
    },
    "SuratNikah": {
        "title": "Surat Pengantar Nikah",
        "type": "object",
        "properties": {
            "pria_pendudukId": { "type": "string" },
            "pria_nama": { "type": "string" },
            "pria_nik": { "type": "string" },
            "wanita_pendudukId": { "type": "string" },
            "wanita_nama": { "type": "string" },
            "wanita_nik": { "type": "string" },
            "status": { "type": "string", "enum": ["Diproses", "Selesai", "Ditolak"] },
            "nomorSurat": { "type": "string" },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["pria_pendudukId", "wanita_pendudukId", "status"]
    },
    "SuratKematian": {
      "title": "Surat Keterangan Kematian",
      "type": "object",
      "properties": {
        "pendudukId": { "type": "string" }, "namaPemohon": { "type": "string" }, "nikPemohon": { "type": "string" },
        "tanggalKematian": { "type": "string", "format": "date" },
        "penyebabKematian": { "type": "string" },
        "status": { "type": "string", "enum": ["Diproses", "Selesai", "Ditolak"] }, "nomorSurat": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["pendudukId", "namaPemohon", "nikPemohon", "tanggalKematian", "penyebabKematian", "status"]
    },
    "SuratPindah": {
      "title": "Surat Keterangan Pindah",
      "type": "object",
      "properties": {
        "pendudukId": { "type": "string" }, "namaPemohon": { "type": "string" }, "nikPemohon": { "type": "string" },
        "alamatTujuan": { "type": "string" },
        "alasanPindah": { "type": "string" },
        "status": { "type": "string", "enum": ["Diproses", "Selesai", "Ditolak"] }, "nomorSurat": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["pendudukId", "namaPemohon", "nikPemohon", "alamatTujuan", "alasanPindah", "status"]
    },
    "SuratPengantar": {
      "title": "Surat Pengantar",
      "type": "object",
      "properties": {
        "pendudukId": { "type": "string" }, "namaPemohon": { "type": "string" }, "nikPemohon": { "type": "string" },
        "keperluan": { "type": "string" },
        "status": { "type": "string", "enum": ["Diproses", "Selesai", "Ditolak"] }, "nomorSurat": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["pendudukId", "namaPemohon", "nikPemohon", "keperluan", "status"]
    },
    "SuratKeterangan": {
      "title": "Surat Keterangan Lainnya",
      "type": "object",
      "properties": {
        "pendudukId": { "type": "string" }, "namaPemohon": { "type": "string" }, "nikPemohon": { "type": "string" },
        "keterangan": { "type": "string" },
        "status": { "type": "string", "enum": ["Diproses", "Selesai", "Ditolak"] }, "nomorSurat": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["pendudukId", "namaPemohon", "nikPemohon", "keterangan", "status"]
    },
    "SuratMasuk": {
      "title": "Surat Masuk",
      "type": "object",
      "properties": {
        "nomorSurat": { "type": "string" },
        "tanggalSurat": { "type": "string", "format": "date" },
        "tanggalDiterima": { "type": "string", "format": "date" },
        "pengirim": { "type": "string" },
        "perihal": { "type": "string" },
        "fileUrl": { "type": "string", "format": "uri" },
        "filePath": { "type": "string" },
        "disposisi": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nomorSurat", "tanggalSurat", "tanggalDiterima", "pengirim", "perihal"]
    },
    "SuratKeluar": {
      "title": "Surat Keluar",
      "type": "object",
      "properties": {
        "nomorSurat": { "type": "string" },
        "tanggalSurat": { "type": "string", "format": "date" },
        "tujuan": { "type": "string" },
        "perihal": { "type": "string" },
        "fileUrl": { "type": "string", "format": "uri" },
        "filePath": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nomorSurat", "tanggalSurat", "tujuan", "perihal"]
    }
  },
  "auth": {
    "providers": [
      "anonymous"
    ]
  },
  "firestore": {
    "/penduduk/{pendudukId}": { "schema": { "$ref": "#/entities/Penduduk" }, "description": "Menyimpan informasi tentang setiap penduduk." },
    "/users/{userId}": { "schema": { "$ref": "#/entities/UserProfile" }, "description": "Menyimpan profil publik pengguna aplikasi." },
    "/workspaces/{workspaceId}": { "schema": { "$ref": "#/entities/Workspace" }, "description": "Menyimpan metadata untuk setiap workspace." },
    "/workspaces/{workspaceId}/items/{itemId}": { "schema": { "$ref": "#/entities/WorkspaceItem" }, "description": "Menyimpan item-item yang ada di dalam sebuah workspace." },
    "/custom_pages/{pageId}": { "schema": { "$ref": "#/entities/CustomPage" }, "description": "Stores content for user-created static pages." },
    "/statistik/{statId}": { "schema": { "$ref": "#/entities/Statistik" }, "description": "Menyimpan data untuk komponen diagram statistik." },
    "/surat_usaha/{suratId}": { "schema": { "$ref": "#/entities/SuratUsaha" }, "description": "Menyimpan data surat keterangan usaha." },
    "/surat_domisili/{suratId}": { "schema": { "$ref": "#/entities/SuratDomisili" }, "description": "Menyimpan data surat keterangan domisili." },
    "/surat_kelahiran/{suratId}": { "schema": { "$ref": "#/entities/SuratKelahiran" }, "description": "Menyimpan data surat keterangan kelahiran." },
    "/surat_nikah/{suratId}": { "schema": { "$ref": "#/entities/SuratNikah" }, "description": "Menyimpan data surat pengantar nikah." },
    "/surat_kematian/{suratId}": { "schema": { "$ref": "#/entities/SuratKematian" }, "description": "Menyimpan data surat keterangan kematian." },
    "/surat_pindah/{suratId}": { "schema": { "$ref": "#/entities/SuratPindah" }, "description": "Menyimpan data surat keterangan pindah." },
    "/surat_pengantar/{suratId}": { "schema": { "$ref": "#/entities/SuratPengantar" }, "description": "Menyimpan data surat pengantar." },
    "/surat_keterangan/{suratId}": { "schema": { "$ref": "#/entities/SuratKeterangan" }, "description": "Menyimpan data surat keterangan lainnya." },
    "/surat_masuk/{suratId}": { "schema": { "$ref": "#/entities/SuratMasuk" }, "description": "Menyimpan data arsip surat masuk." },
    "/surat_keluar/{suratId}": { "schema": { "$ref": "#/entities/SuratKeluar" }, "description": "Menyimpan data arsip surat keluar." }
  }
}
