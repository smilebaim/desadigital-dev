{
  "entities": {
    "Penduduk": {
      "title": "Penduduk",
      "type": "object",
      "properties": {
        "nama": {
          "type": "string",
          "description": "Nama lengkap penduduk."
        },
        "nik": {
          "type": "string",
          "description": "Nomor Induk Kependudukan."
        },
        "kk": {
          "type": "string",
          "description": "Nomor Kartu Keluarga."
        },
        "jenisKelamin": {
          "type": "string",
          "enum": [
            "Laki-laki",
            "Perempuan"
          ]
        },
        "tempatLahir": {
          "type": "string"
        },
        "tanggalLahir": {
          "type": "string",
          "format": "date"
        },
        "agama": {
          "type": "string"
        },
        "pendidikan": {
          "type": "string"
        },
        "pekerjaan": {
          "type": "string"
        },
        "statusPerkawinan": {
          "type": "string",
          "enum": [
            "Belum Kawin",
            "Kawin",
            "Cerai Hidup",
            "Cerai Mati"
          ]
        },
        "alamat": {
          "type": "string"
        },
        "rt": {
          "type": "string"
        },
        "rw": {
          "type": "string"
        }
      },
      "required": [
        "nama",
        "nik",
        "kk",
        "jenisKelamin",
        "tempatLahir",
        "tanggalLahir",
        "agama",
        "pendidikan",
        "pekerjaan",
        "statusPerkawinan",
        "alamat",
        "rt",
        "rw"
      ]
    },
    "Workspace": {
      "title": "Workspace",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Nama dari workspace."
        },
        "description": {
          "type": "string",
          "description": "Deskripsi singkat dari workspace."
        },
        "ownerUid": {
          "type": "string",
          "description": "User ID dari pemilik workspace."
        }
      },
      "required": [
        "name",
        "ownerUid"
      ]
    },
    "WorkspaceItem": {
      "title": "Workspace Item",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Judul dari item workspace."
        },
        "description": {
          "type": "string",
          "description": "Deskripsi atau catatan detail dari item."
        },
        "completed": {
          "type": "boolean",
          "description": "Status penyelesaian item."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Waktu item dibuat."
        }
      },
      "required": [
        "title"
      ]
    }
  },
  "auth": {
    "providers": [
      "anonymous"
    ]
  },
  "firestore": {
    "/penduduk/{pendudukId}": {
      "schema": {
        "$ref": "#/entities/Penduduk"
      },
      "description": "Menyimpan informasi tentang setiap penduduk."
    },
    "/workspaces/{workspaceId}": {
      "schema": {
        "$ref": "#/entities/Workspace"
      },
      "description": "Menyimpan metadata untuk setiap workspace."
    },
    "/workspaces/{workspaceId}/items/{itemId}": {
      "schema": {
        "$ref": "#/entities/WorkspaceItem"
      },
      "description": "Menyimpan item-item yang ada di dalam sebuah workspace."
    }
  }
}
