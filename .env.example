# =============================================================================
# DESAHUB - Environment Variables Template
# =============================================================================
# Salin file ini menjadi `.env.local` untuk development lokal.
# JANGAN pernah commit file .env.local ke Git!
# Isi nilai-nilai ini dari Firebase Console: https://console.firebase.google.com
# =============================================================================

# Firebase Client SDK (NEXT_PUBLIC = aman diekspos ke browser)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-ABCDEF1234

# Google Generative AI (Gemini) - Dapatkan dari https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=AIzaSy...

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=DesaHub
