# =============================================================================
# DESAHUB - Environment Variables for PRODUCTION (Vercel / Hosting)
# =============================================================================
# Salin isi file ini ke "Environment Variables" di Vercel Dashboard.
# Project Settings → Environment Variables → Add each key below.
# JANGAN pernah commit file ini jika sudah diisi ke Git!
# =============================================================================

# Firebase Client SDK (NEXT_PUBLIC = aman diekspos ke browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Google Generative AI (Gemini)
# Dapatkan dari: https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=

# =============================================================================
# ⚠️  KRUSIAL untuk Routing Multi-Tenant Subdomain yang Benar!
# =============================================================================
# Isi dengan domain UTAMA platform DesaHub Anda (bukan subdomain desa).
# Contoh domain bertingkat Vercel/cPanel:
#   NEXT_PUBLIC_APP_URL=https://develop.domainsaya.domainutamadarihosting.com
# Contoh domain langsung:
#   NEXT_PUBLIC_APP_URL=https://desahub.id
# Contoh Vercel preview deployment:
#   NEXT_PUBLIC_APP_URL=https://desa-lengkap.vercel.app
NEXT_PUBLIC_APP_URL=

# Nama aplikasi (tampil di metadata browser)
NEXT_PUBLIC_APP_NAME=DesaHub
