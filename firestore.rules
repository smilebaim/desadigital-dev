
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Aturan keamanan yang dilonggarkan untuk pengembangan
    // Mengizinkan semua orang untuk membaca data
    // Mengizinkan semua pengguna yang terautentikasi untuk menulis data
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
