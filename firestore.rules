
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // WARNING: These rules are very permissive and are intended for development only.
    // They allow any user to read any data, and any authenticated user to write any data.
    // You should secure your data before deploying to production.
    match /{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
