
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // PERINGATAN: Aturan keamanan sangat longgar untuk pengembangan.
    // Mengizinkan siapa saja untuk membaca dan menulis ke database.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
