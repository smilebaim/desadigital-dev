
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow users to read and write their own workspaces
    match /workspaces/{workspaceId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.ownerUid;
      
      // Allow users to read, write, and delete items within their own workspace
      match /items/{itemId} {
        allow read, write, delete: if request.auth != null && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerUid == request.auth.uid;
      }
    }

    // Allow any authenticated user to read and write site settings
    // This is for admin dashboard functionality
    match /siteSettings/{document} {
      allow read, write: if request.auth != null;
    }

    // Allow any authenticated user to manage posts
    match /posts/{postId} {
      allow read, create, update, delete: if request.auth != null;
    }

    // Allow any authenticated user to manage menus
    match /menus/{menuId} {
       allow read, write: if request.auth != null;
    }

    // Allow any authenticated user to manage map markers
    match /mapMarkers/{markerId} {
      allow read, create, update, delete: if request.auth != null;
    }

    // Allow any authenticated user to manage map polygons
    match /mapPolygons/{polygonId} {
      allow read, create, update, delete: if request.auth != null;
    }

    // Allow any authenticated user to manage map layer categories
    match /mapLayerCategories/{categoryId} {
      allow read, create, update, delete: if request.auth != null;
    }
  }
}
