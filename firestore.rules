
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // WARNING: These rules are extremely permissive and are for development convenience only.
    // They allow ANY user (authenticated or not) to read AND write to your entire database.
    // You MUST secure your data before deploying to production.
    match /{document=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
